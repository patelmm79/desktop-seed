# OpenCLAW Configuration
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to version control!

# OpenRouter API (required for Claude AI)
OPENROUTER_API_KEY=

# Discord Bot Configuration
DISCORD_BOT_TOKEN=
DISCORD_ALLOWLIST_IDS=
DISCORD_CHANNEL_ID=

# CVE Monitoring Webhook (for security alerts)
DISCORD_CVE_WEBHOOK_URL=

# Token Rotation Configuration (days)
# Override default rotation periods if needed
# TOKEN_ROTATION_DAYS_API_KEY=90    # Default: 90 days for API keys
# TOKEN_ROTATION_DAYS_WEBHOOK=180   # Default: 180 days for webhooks
# TOKEN_ALERT_THRESHOLD_DAYS=80     # Default: 80 days (alert before rotation)